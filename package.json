{
  "name": "noc-hub",
  "version": "1.0.0",
  "description": "NOC Team Hub — Team coordination, runbook, incident log, vendor monitor, shift handoff",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "cd client && npm install && npm run build",
    "dev": "nodemon server.js",
    "prod": "pm2 start server.js --name noc-hub",
    "stop": "pm2 stop noc-hub",
    "restart": "pm2 restart noc-hub",
    "logs": "pm2 logs noc-hub",
    "status": "pm2 status"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "localtunnel": "^2.0.2",
    "socket.io": "^4.8.3",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
